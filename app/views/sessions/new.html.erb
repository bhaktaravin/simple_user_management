<h1>Login</h1>

<%= form_with url: login_path do |f| %>
  <div>
    <%= f.label :email %>
    <%= f.email_field :email, required: true %>
  </div>
  <div>
    <%= f.label :password %>
    <%= f.password_field :password, required: true %>
  </div>
  <%= f.submit "Log in" %>
<% end %>

<p><%= link_to "Sign up", signup_path %></p>
